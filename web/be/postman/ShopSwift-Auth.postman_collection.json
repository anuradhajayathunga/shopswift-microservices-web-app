{
  "info": {
    "_postman_id": "8ee911d0-1338-4a74-a673-f16166d5ca42",
    "name": "ShopSwift Auth + Protected APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        }
      },
      "response": []
    },
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{test_name}}\",\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/gateway/users",
          "host": ["{{base_url}}"],
          "path": ["gateway", "users"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register returns 201 or 400 (already exists)', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/gateway/auth/login",
          "host": ["{{base_url}}"],
          "path": ["gateway", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains access_token', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  pm.expect(responseBodyJson).to.have.property('access_token');",
              "  pm.expect(responseBodyJson).to.have.property('token_type');",
              "});",
              "",
              "pm.test('Store JWT token in environment', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  pm.environment.set('jwt_token', responseBodyJson.access_token);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Get Users (Protected)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/gateway/users",
          "host": ["{{base_url}}"],
          "path": ["gateway", "users"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  pm.expect(responseBodyJson).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Create Order (Protected)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": 1,\n  \"product_id\": 1,\n  \"quantity\": 1,\n  \"total_price\": 99.99\n}"
        },
        "url": {
          "raw": "{{base_url}}/gateway/orders",
          "host": ["{{base_url}}"],
          "path": ["gateway", "orders"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Order create returns expected status', function () {",
              "  pm.expect([201, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "response": []
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    }
  ]
}
